# FAL.ai API key -- get yours at https://fal.ai/dashboard
FAL_KEY=your-fal-key-here

# Express server port
PORT=3000

# Path to Blender executable (Quality Tier only)
# macOS:  /Applications/Blender.app/Contents/MacOS/Blender
# Linux:  /usr/bin/blender  or  /usr/local/bin/blender
# Docker: use the gravitaslabs/blender image
BLENDER_PATH=/usr/bin/blender

# Output directory for Blender quality renders
OUTPUT_DIR=/tmp/renders

# Optional: secret for validating incoming webhooks
WEBHOOK_SECRET=change-me-in-production
